root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 88

[*.{js,mjs,cjs,ts,mts,cts,jsx,tsx,njk,css,scss,html}]
indent_size = 2

[*.{yml,yaml,toml,json,jsonc}]
indent_size = 2

[*.md]
# Markdown can use trailing whitespace for hard line breaks.
trim_trailing_whitespace = false
