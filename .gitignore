# data (keep repo lean & safe)
*.parquet
*.xlsx
*.xls
*.zip
data-raw/
**/temp/
**/tmp/

# project data — never commit real records (PII) or pipeline outputs
data/raw/*
data/processed/*
# (the anonymized, PII-removed dataset is published under data/sample/ instead)

# assets/*.mp4 is tracked via Git LFS (see .gitattributes) — intentionally NOT ignored

# raw report scrapes (contain original names/identifiers; curated copies live in reports/)
reports/_source/

# Word originals kept locally for reference; canonical docs are the .md files
docs/*.docx

# experiments live outside the package and outside git; promotion is by
# re-authoring through the project's standards into src/vendorscope/
scratch/

# notebooks & tooling
.ipynb_checkpoints/
.env
.venv/
__pycache__/
*.log

# OS/editor
.DS_Store
Thumbs.db
.vscode/
